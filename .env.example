# Sanity CMS
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Behold.so (optional — auto-pull Instagram posts for "Latest" section)
PUBLIC_BEHOLD_FEED_ID=

# Local preview only — set to "true" to render mock Instagram posts
# in the "Latest" section without signing up for Behold. Useful for demos.
# Leave empty or unset in production.
INSTAGRAM_MOCK=

# Airtable (contact form CRM)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Inquiries

# Resend (contact form email notification)
RESEND_API_KEY=
NOTIFICATION_EMAIL=hello@theplayablenetwork.org
NOTIFICATION_FROM=noreply@theplayablenetwork.org
