---
import { useTranslations, type Locale } from '@/i18n/config';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = `/${locale}`;
---

<footer class="border-t border-gray-200 bg-gray-50">
  <div class="container mx-auto px-4 py-12">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <Logo locale={locale} size="sm" />
        <p class="mt-4 max-w-sm text-sm text-gray-600">{t.footer.tagline}</p>
        <p class="mt-2 text-sm text-gray-500">{t.footer.addressLine}</p>
        <p class="mt-1 text-sm text-gray-500">
          <a href="mailto:playablenetwork.ke@gmail.com" class="hover:text-brand hover:underline">
            playablenetwork.ke@gmail.com
          </a>
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500">{t.footer.exploreTitle}</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href={`${base}/about`} class="text-gray-700 hover:text-brand">{t.nav.about}</a></li>
          <li><a href={`${base}/programs`} class="text-gray-700 hover:text-brand">{t.nav.programs}</a></li>
          <li><a href={`${base}/impact`} class="text-gray-700 hover:text-brand">{t.nav.impact}</a></li>
          <li><a href={`${base}/partners`} class="text-gray-700 hover:text-brand">{t.nav.partners}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500">{t.footer.connectTitle}</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href={`${base}/contact`} class="text-gray-700 hover:text-brand">{t.nav.contact}</a></li>
          <li><a href={`${base}/support`} class="text-gray-700 hover:text-brand">{t.nav.support}</a></li>
          <li><a href={`${base}/governance`} class="text-gray-700 hover:text-brand">{t.nav.governance}</a></li>
          <li>
            <a href="https://www.instagram.com/theplayablenetwork" class="text-gray-700 hover:text-brand">Instagram</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-gray-200 pt-6 text-xs text-gray-500">
      {t.footer.copyright}
    </div>
  </div>
</footer>
