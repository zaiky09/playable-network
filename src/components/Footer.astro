---
import { useTranslations, type Locale } from '@/i18n/config';
import Logo from './Logo.astro';
import SocialLinks from './SocialLinks.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = `/${locale}`;

// Single source of truth for the main nav set — mirrors the Header desktop
// nav exactly so users see the same options in both surfaces.
const mainNav = [
  { href: `${base}/about`,     label: t.nav.about },
  { href: `${base}/framework`, label: t.nav.framework },
  { href: `${base}/programs`,  label: t.nav.programs },
  { href: `${base}/impact`,    label: t.nav.impact },
  { href: `${base}/partners`,  label: t.nav.partners },
  { href: `${base}/contact`,   label: t.nav.contact },
];

// Hover color matches the Header (text-brand-gold). Centralised so a future
// recolor is one line.
const linkClass = 'font-semibold transition hover:text-brand-gold';
---

<footer class="bg-slate-950 text-slate-100">
  <div class="container mx-auto px-4 py-14">
    <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
      <div class="md:col-span-2">
        <Logo locale={locale} size="md" class="max-w-[12rem]" />
        <p class="mt-4 max-w-xl text-sm leading-7 text-slate-300">{t.footer.tagline}</p>

        <div class="mt-6 space-y-3 text-sm text-slate-400">
          <p>{t.footer.addressLine}</p>
          <p>
            <a href="mailto:playablenetwork.ke@gmail.com" class={`inline-flex items-center text-slate-100 transition hover:text-brand-gold hover:underline`}>
              playablenetwork.ke@gmail.com
            </a>
          </p>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-bold uppercase tracking-[0.24em] text-slate-100">{t.footer.exploreTitle}</h4>
        <ul class="mt-5 space-y-3 text-sm text-slate-300">
          {
            mainNav.map((item) => (
              <li><a href={item.href} class={linkClass}>{item.label}</a></li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-bold uppercase tracking-[0.24em] text-slate-100">{t.footer.connectTitle}</h4>
        <ul class="mt-5 space-y-3 text-sm text-slate-300">
          <li><a href={`${base}/support`} class={linkClass}>{t.nav.support}</a></li>
          <li><a href={`${base}/governance`} class={linkClass}>{t.nav.governance}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 flex justify-center border-t border-slate-800 pt-6">
      <SocialLinks locale={locale} variant="compact" theme="dark" />
    </div>

    <div class="mt-10">
      <div class="grid gap-4 rounded-3xl border border-slate-800 bg-slate-900/90 p-6 text-sm text-slate-300 shadow-xl shadow-slate-950/20 sm:grid-cols-2 sm:items-center">
        <div class="order-2 sm:order-1 text-center text-slate-400 sm:text-left">{t.footer.copyright}</div>
        <div class="order-1 sm:order-2 border-t border-slate-800 pt-4 text-center sm:border-t-0 sm:pt-0 sm:text-right">
          <div class="flex flex-wrap justify-center gap-3 text-sm sm:justify-end">
            <a href={`${base}/`} class={linkClass}>{t.nav.home}</a>
            {mainNav.map((item) => (
              <a href={item.href} class={linkClass}>{item.label}</a>
            ))}
            <a href={`${base}/support`} class={linkClass}>{t.nav.support}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
