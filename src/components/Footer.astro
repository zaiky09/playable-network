---
import { useTranslations, type Locale } from '@/i18n/config';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = `/${locale}`;
---

<footer class="bg-slate-950 text-slate-100">
  <div class="container mx-auto px-4 py-14">
    <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
      <div class="md:col-span-2">
        <Logo locale={locale} size="md" class="max-w-[12rem]" />
        <p class="mt-4 max-w-xl text-sm leading-7 text-slate-300">{t.footer.tagline}</p>

        <div class="mt-6 space-y-3 text-sm text-slate-400">
          <p>{t.footer.addressLine}</p>
          <p>
            <a href="mailto:playablenetwork.ke@gmail.com" class="inline-flex items-center text-slate-100 transition hover:text-brand hover:underline">
              playablenetwork.ke@gmail.com
            </a>
          </p>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-bold uppercase tracking-[0.24em] text-slate-100">{t.footer.exploreTitle}</h4>
        <ul class="mt-5 space-y-3 text-sm text-slate-300">
          <li><a href={`${base}/about`} class="font-semibold transition hover:text-brand">{t.nav.about}</a></li>
          <li><a href={`${base}/programs`} class="font-semibold transition hover:text-brand">{t.nav.programs}</a></li>
          <li><a href={`${base}/impact`} class="font-semibold transition hover:text-brand">{t.nav.impact}</a></li>
          <li><a href={`${base}/partners`} class="font-semibold transition hover:text-brand">{t.nav.partners}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-bold uppercase tracking-[0.24em] text-slate-100">{t.footer.connectTitle}</h4>
        <ul class="mt-5 space-y-3 text-sm text-slate-300">
          <li><a href={`${base}/contact`} class="font-semibold transition hover:text-brand">{t.nav.contact}</a></li>
          <li><a href={`${base}/support`} class="font-semibold transition hover:text-brand">{t.nav.support}</a></li>
          <li><a href={`${base}/governance`} class="font-semibold transition hover:text-brand">{t.nav.governance}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 flex justify-center border-t border-slate-800 pt-6">
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="https://www.instagram.com/theplayablenetwork" aria-label="Instagram" class="rounded-full bg-slate-900/90 p-2 transition hover:bg-brand">
          <img src="/SocialMediaIcons/instagramIcon.jpg" alt="Instagram" class="h-6 w-6 object-contain" />
        </a>
        <a href="https://www.facebook.com/theplayablenetwork" aria-label="Facebook" class="rounded-full bg-slate-900/90 p-2 transition hover:bg-brand">
          <img src="/SocialMediaIcons/facebookIcon.jpg" alt="Facebook" class="h-6 w-6 object-contain" />
        </a>
        <a href="https://www.linkedin.com/company/theplayablenetwork" aria-label="LinkedIn" class="rounded-full bg-slate-900/90 p-2 transition hover:bg-brand">
          <img src="/SocialMediaIcons/linkedInIcon.jpg" alt="LinkedIn" class="h-6 w-6 object-contain" />
        </a>
        <a href="https://www.tiktok.com/@theplayablenetwork" aria-label="TikTok" class="rounded-full bg-slate-900/90 p-2 transition hover:bg-brand">
          <img src="/SocialMediaIcons/tiktokIcon.jpg" alt="TikTok" class="h-6 w-6 object-contain" />
        </a>
      </div>
    </div>

    <div class="mt-10">
      <div class="grid gap-4 rounded-3xl border border-slate-800 bg-slate-900/90 p-6 text-sm text-slate-300 shadow-xl shadow-slate-950/20 sm:grid-cols-2 sm:items-center">
        <div class="order-2 sm:order-1 text-center text-slate-400 sm:text-left">{t.footer.copyright}</div>
        <div class="order-1 sm:order-2 border-t border-slate-800 pt-4 text-center sm:border-t-0 sm:pt-0 sm:text-right">
          <div class="flex flex-wrap justify-center gap-3 text-sm sm:justify-end">
            <a href={`${base}/`} class="font-semibold transition hover:text-brand">{t.nav.home}</a>
            <a href={`${base}/about`} class="font-semibold transition hover:text-brand">{t.nav.about}</a>
            <a href={`${base}/programs`} class="font-semibold transition hover:text-brand">{t.nav.programs}</a>
            <a href={`${base}/impact`} class="font-semibold transition hover:text-brand">{t.nav.impact}</a>
            <a href={`${base}/partners`} class="font-semibold transition hover:text-brand">{t.nav.partners}</a>
            <a href={`${base}/contact`} class="font-semibold transition hover:text-brand">{t.nav.contact}</a>
            <a href={`${base}/support`} class="font-semibold transition hover:text-brand">{t.nav.support}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
