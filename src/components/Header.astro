---
import { useTranslations, type Locale } from '@/i18n/config';
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  isHomePage?: boolean;
}

const { locale, isHomePage = false } = Astro.props;
const t = useTranslations(locale);
const base = `/${locale}`;
const pathname = Astro.url.pathname;
const pathWithoutLocale = pathname.replace(/^\/[a-z]{2}(?=\/|$)/, '') || '/';
const navLinkClass = (path: string) => `text-black font-semibold hover:text-brand-gold ${pathWithoutLocale === path ? 'text-brand-accent underline underline-offset-8 decoration-brand-accent' : ''}`;
---

<header class={`relative z-30 transition ${isHomePage ? 'absolute inset-x-0 top-0 border-none bg-transparent md:bg-black/10 md:backdrop-blur-sm' : 'border-b border-gray-200 bg-white'}`}>
  <nav class="container mx-auto flex items-center justify-between gap-4 px-4 py-3">
    <a
      href={`${base}/`}
      class="inline-flex shrink-0 items-center rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
      aria-label={`${t.meta.siteName} — ${t.nav.home}`}
    >
      <Logo locale={locale} size="md" />
    </a>

    <button
      id="mobile-menu-button"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="inline-flex items-center justify-center rounded border border-gray-200 p-2 text-gray-700 transition hover:bg-gray-100 md:hidden"
    >
      <span class="sr-only">Open navigation menu</span>
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden gap-8 text-sm tracking-wide md:flex">
      <li><a href={`${base}/about`} class={navLinkClass('/about')}>{t.nav.about}</a></li>
      <li><a href={`${base}/programs`} class={navLinkClass('/programs')}>{t.nav.programs}</a></li>
      <li><a href={`${base}/impact`} class={navLinkClass('/impact')}>{t.nav.impact}</a></li>
      <li><a href={`${base}/partners`} class={navLinkClass('/partners')}>{t.nav.partners}</a></li>
      <li><a href={`${base}/contact`} class={navLinkClass('/contact')}>{t.nav.contact}</a></li>
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={`${base}/support`}
        class="hidden rounded bg-brand-accent px-4 py-2 text-sm font-semibold text-white hover:bg-brand-accent-dark md:inline-block"
      >
        {t.nav.support}
      </a>
      <LanguageSwitcher currentLocale={locale} />
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-gray-200 bg-white md:hidden">
    <div class="space-y-3 px-4 py-4">
      <a href={`${base}/about`} class="block rounded px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">{t.nav.about}</a>
      <a href={`${base}/programs`} class="block rounded px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">{t.nav.programs}</a>
      <a href={`${base}/impact`} class="block rounded px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">{t.nav.impact}</a>
      <a href={`${base}/partners`} class="block rounded px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">{t.nav.partners}</a>
      <a href={`${base}/contact`} class="block rounded px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">{t.nav.contact}</a>
      <a href={`${base}/support`} class="block rounded bg-brand-accent px-3 py-2 text-sm font-semibold text-white hover:bg-brand-accent-dark">{t.nav.support}</a>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const button = document.getElementById('mobile-menu-button');
      const menu = document.getElementById('mobile-menu');
      if (!button || !menu) return;

      button.addEventListener('click', () => {
        const isHidden = menu.classList.toggle('hidden');
        button.setAttribute('aria-expanded', String(!isHidden));
      });
    });
  </script>
  </nav>
</header>
