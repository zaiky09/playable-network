---
import { getLatestPosts, type LatestPost } from '@/lib/sanity';
import { getInstagramPosts, type BeholdPost } from '@/lib/instagram';
import { useTranslations, type Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

interface DisplayItem {
  id: string;
  caption: string;
  imageUrl: string | null;
  link: string | null;
  date: string | null;
}

// Priority: Sanity (NGO-curated) → Behold (auto Instagram) → static i18n fallback
const sanityPosts = await getLatestPosts(3);

let items: DisplayItem[];
let source: 'sanity' | 'behold' | 'fallback';

if (sanityPosts && sanityPosts.length > 0) {
  source = 'sanity';
  items = sanityPosts.map((p: LatestPost) => ({
    id: p._id,
    caption: p.caption,
    imageUrl: p.image?.asset?.url ?? null,
    link: p.instagramUrl ?? null,
    date: p.publishedAt,
  }));
} else {
  const beholdPosts = await getInstagramPosts(3);
  if (beholdPosts && beholdPosts.length > 0) {
    source = 'behold';
    items = beholdPosts.map((p: BeholdPost) => ({
      id: p.id,
      caption: p.prunedCaption || p.caption,
      imageUrl: p.sizes?.medium?.mediaUrl ?? p.thumbnailUrl ?? p.mediaUrl,
      link: p.permalink,
      date: p.timestamp,
    }));
  } else {
    source = 'fallback';
    items = t.latest.fallback.map((f, i) => ({
      id: `fallback-${i}`,
      caption: f.caption,
      imageUrl: null,
      link: f.link || null,
      date: null,
    }));
  }
}

const dateFmt = new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'short', day: 'numeric' });
---

<section class="bg-gray-900 py-20" data-source={source}>
  <div class="container mx-auto px-4">
    <div class="flex items-baseline justify-between mb-12">
      <div>
        <h2 class="text-4xl font-bold text-white">{t.latest.title}</h2>
        <p class="mt-2 text-sm text-gray-400">From @theplayablenetwork</p>
      </div>
      <a
        href="https://www.instagram.com/theplayablenetwork"
        class="flex items-center gap-2 rounded-full bg-brand-accent px-5 py-2.5 text-sm font-semibold text-white shadow-lg transition hover:bg-brand-accent-dark"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.765 8.035 11.591.6.111.82-.26.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.219.694.825.576C20.565 21.795 24 17.31 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        {t.latest.followCta}
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-3 lg:gap-8">
      {
        items.map((item) => (
          <article class="group relative overflow-hidden rounded-2xl bg-gray-800 shadow-lg transition hover:shadow-2xl">
            <div class="relative aspect-square overflow-hidden bg-gradient-to-br from-brand to-brand-accent">
              {item.imageUrl ? (
                <img
                  src={item.imageUrl}
                  alt=""
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-110"
                  loading="lazy"
                />
              ) : (
                <div class="flex items-center justify-center h-full w-full bg-gradient-to-br from-brand-light to-brand-cyan">
                  <svg class="h-12 w-12 text-white/40" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54h2.86l2.43-3.24 1.5 2h2.92L16.96 9.5z"/>
                  </svg>
                </div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 transition duration-300 group-hover:opacity-100" />
            </div>
            <div class="absolute inset-0 flex flex-col justify-end p-4 opacity-0 transition duration-300 group-hover:opacity-100">
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-2">
                {item.date && dateFmt.format(new Date(item.date))}
              </p>
              <p class="text-sm text-white leading-snug line-clamp-3 mb-3">{item.caption}</p>
              {item.link && (
                <a
                  href={item.link}
                  target="_blank"
                  class="inline-flex items-center gap-2 text-xs font-semibold text-brand-accent hover:text-brand-gold transition"
                >
                  View post
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6v12h12v-6m0-6l-7 7" />
                  </svg>
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
