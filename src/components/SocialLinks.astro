---
import { useTranslations, type Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
  /**
   * 'compact' — icon only (default).
   * 'labeled' — icon + visible text label next to it.
   */
  variant?: 'compact' | 'labeled';
  /**
   * 'light' — for use on light/white backgrounds (e.g. contact page).
   *           Brand-colored SVG, transparent wrapper, brand-accent hover.
   * 'dark'  — for use on dark backgrounds (e.g. footer).
   *           White SVG in a slate-900 rounded pill, brand-accent on hover.
   */
  theme?: 'light' | 'dark';
  class?: string;
}

const { locale, variant = 'compact', theme = 'light', class: className = '' } = Astro.props;
const t = useTranslations(locale);
const s = t.socials;

const linkClass =
  theme === 'dark'
    ? 'group inline-flex items-center gap-2 rounded-full bg-slate-900/90 p-2 transition hover:bg-brand-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950'
    : 'group inline-flex items-center gap-2 rounded-full p-2 transition hover:bg-brand-accent/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2';

const iconClass =
  theme === 'dark'
    ? 'h-5 w-5 text-slate-100 transition group-hover:text-white'
    : 'h-5 w-5 text-brand transition group-hover:text-brand-accent';

const labelClass =
  theme === 'dark'
    ? 'text-sm text-slate-200 group-hover:text-white'
    : 'text-sm text-gray-700 group-hover:text-brand';
---

<ul class={`flex flex-wrap items-center gap-3 ${className}`}>
  {/* Instagram */}
  <li>
    <a
      href={s.instagram.url}
      target="_blank"
      rel="noopener noreferrer me"
      aria-label={`${s.instagram.label} — ${s.instagram.handle}`}
      class={linkClass}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={iconClass}>
        <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd"/>
      </svg>
      {variant === 'labeled' && <span class={labelClass}>{s.instagram.label}</span>}
    </a>
  </li>

  {/* Facebook */}
  <li>
    <a
      href={s.facebook.url}
      target="_blank"
      rel="noopener noreferrer me"
      aria-label={`${s.facebook.label} — ${s.facebook.handle}`}
      class={linkClass}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={iconClass}>
        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.99 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
      </svg>
      {variant === 'labeled' && <span class={labelClass}>{s.facebook.label}</span>}
    </a>
  </li>

  {/* LinkedIn */}
  {s.linkedin && (
    <li>
      <a
        href={s.linkedin.url}
        target="_blank"
        rel="noopener noreferrer me"
        aria-label={`${s.linkedin.label} — ${s.linkedin.handle}`}
        class={linkClass}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={iconClass}>
          <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.339 18.337v-8.59H5.667v8.59h2.672zM7.003 8.574a1.548 1.548 0 1 0 0-3.096 1.548 1.548 0 0 0 0 3.096zm11.335 9.763V13.59c0-2.578-1.42-3.779-3.21-3.779-1.444 0-2.099.794-2.464 1.351v-1.157h-2.661c.035.75 0 8.59 0 8.59h2.66v-4.798c0-.244.023-.49.094-.668.193-.488.643-.998 1.396-.998.985 0 1.382.748 1.382 1.846v4.618h2.803z"/>
        </svg>
        {variant === 'labeled' && <span class={labelClass}>{s.linkedin.label}</span>}
      </a>
    </li>
  )}

  {/* TikTok */}
  <li>
    <a
      href={s.tiktok.url}
      target="_blank"
      rel="noopener noreferrer me"
      aria-label={`${s.tiktok.label} — ${s.tiktok.handle}`}
      class={linkClass}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={iconClass}>
        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1Z"/>
      </svg>
      {variant === 'labeled' && <span class={labelClass}>{s.tiktok.label}</span>}
    </a>
  </li>
</ul>
