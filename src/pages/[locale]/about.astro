---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, useTranslations, type Locale } from '@/i18n/config';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const base = `/${locale}`;
---

<BaseLayout locale={locale} title={t.about.title} description={t.about.metaDescription}>
  <section class="relative isolate overflow-hidden bg-brand-dark text-white">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/video/impact-poster.jpg"
      aria-hidden="true"
      class="absolute inset-0 -z-10 h-full w-full object-cover motion-reduce:hidden"
      disablepictureinpicture
    >
      <source src="/video/AboutUs-mobile.mp4" type="video/mp4" media="(max-width: 768px)" />
      <source src="/video/AboutUs.mp4" type="video/mp4" />
    </video>

    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 bg-gradient-to-br from-brand-dark/85 via-brand-dark/75 to-brand-accent/40"
    ></div>

    <div class="container mx-auto flex min-h-[70vh] flex-col justify-center px-4 py-24 md:min-h-[75vh]">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-gold drop-shadow">
        Our story
      </p>
      <h1 class="mt-4 text-4xl font-bold leading-tight tracking-tight text-white drop-shadow-lg md:text-6xl lg:text-7xl">
        {t.about.title}
      </h1>
      <p class="mt-6 max-w-3xl text-xl font-medium text-brand-accent drop-shadow md:text-2xl">
        {t.about.tagline}
      </p>
      <p class="mt-6 max-w-3xl text-lg text-white/90 drop-shadow md:text-xl">
        {t.about.intro}
      </p>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <div class="grid gap-10 md:grid-cols-2 md:items-center">
        <div>
          <h2 class="text-2xl font-bold text-brand">{t.about.storyTitle}</h2>
          <div class="mt-6 space-y-4 text-gray-700">
            {t.about.storyBody.split('\n\n').map((p) => <p>{p}</p>)}
          </div>
        </div>
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img
            src="/photos/WhoWeAre.webp"
            alt="PlayAble Network team and community members"
            width="500"
            height="500"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 py-16">
    <div class="grid gap-10 md:grid-cols-2">
      <div class="rounded-lg border-l-4 border-brand-accent bg-white p-6 shadow-sm">
        <h3 class="text-xl font-bold text-brand">{t.about.visionTitle}</h3>
        <p class="mt-3 text-gray-700">{t.about.visionBody}</p>
      </div>
      <div class="rounded-lg border-l-4 border-brand bg-white p-6 shadow-sm">
        <h3 class="text-xl font-bold text-brand">{t.about.missionTitle}</h3>
        <p class="mt-3 text-gray-700">{t.about.missionBody}</p>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand">{t.about.teamTitle}</h2>
      <p class="mt-2 max-w-2xl text-gray-700">{t.about.teamIntro}</p>
      <div class="mt-10 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {
          t.about.teamMembers.map((person) => (
            <article class="rounded-lg bg-white p-6 shadow-sm">
              <div class="aspect-square w-full overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-200">
                <img
                  src={`/team/${person.name.toLowerCase().replace(/\s+/g, "-")}.webp`}
                  alt={person.name}
                  width="200"
                  height="200"
                  class="h-full w-full object-cover transition duration-300 hover:scale-[1.02]"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </div>
              <h3 class="mt-4 text-lg font-bold text-brand">{person.name}</h3>
              <p class="mt-1 text-sm font-semibold text-brand-accent">{person.role}</p>
              <p class="mt-3 text-sm text-gray-700">{person.bio}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 py-16">
    <div class="rounded-lg bg-brand p-10 text-white">
      <h2 class="text-2xl font-bold">{t.support.contactTitle}</h2>
      <p class="mt-3 max-w-2xl text-blue-100">{t.support.contactBody}</p>
      <a
        href={`${base}/contact`}
        class="mt-6 inline-block rounded bg-brand-accent px-5 py-2.5 font-semibold text-white hover:bg-brand-accent-dark"
      >
        {t.support.ctaText}
      </a>
    </div>
  </section>
</BaseLayout>
