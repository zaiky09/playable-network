---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, useTranslations, type Locale } from '@/i18n/config';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const base = `/${locale}`;
---

<BaseLayout locale={locale} title={t.governance.title} description={t.governance.metaDescription}>
  <section class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-brand md:text-5xl">{t.governance.title}</h1>
    <p class="mt-6 max-w-3xl text-lg text-gray-700">{t.governance.intro}</p>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand">{t.governance.safeguardingTitle}</h2>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          t.governance.safeguardingItems.map((item) => (
            <li class="flex items-start gap-3 rounded-lg bg-white p-4 shadow-sm">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mt-0.5 h-5 w-5 shrink-0 text-brand-accent"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-sm text-gray-800">{item}</span>
            </li>
          ))
        }
      </ul>
      <p class="mt-8 max-w-3xl text-gray-700">{t.governance.safeguardingFooter}</p>
    </div>
  </section>

  <section class="container mx-auto px-4 py-16">
    <div class="rounded-lg border-l-4 border-brand bg-white p-8 shadow-sm">
      <h2 class="text-2xl font-bold text-brand">{t.governance.complianceTitle}</h2>
      <p class="mt-4 max-w-3xl text-gray-700">{t.governance.complianceBody}</p>
      <a
        href={`${base}/contact`}
        class="mt-6 inline-block rounded border border-brand px-5 py-2.5 font-semibold text-brand hover:bg-brand hover:text-white"
      >
        {t.nav.contact}
      </a>
    </div>
  </section>
</BaseLayout>
