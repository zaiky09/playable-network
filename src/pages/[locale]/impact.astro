---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, useTranslations, type Locale } from '@/i18n/config';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const base = `/${locale}`;

const galleries: Record<string, string[]> = {
  turkana: [
    'turkana-coach-equipment-distribution.jpg',
    'turkana-mentoring-session-03.jpg',
    'turkana-players-huddle-dirt-pitch.jpg',
    'turkana-pitch-training-01.jpg',
    'turkana-match-orange-vests-dirt-field.jpg',
    'turkana-coach-training-session.jpg',
  ],
  mombasa: [
    'mombasa-match-02.jpg',
    'mombasa-match-03.jpg',
    'mombasa-match-04.jpg',
    'mombasa-match-05.jpg',
    'mombasa-match-06.jpg',
    'mombasa-group.jpg',
  ],
};
---

<BaseLayout locale={locale} title={t.impact.title}>
  <section class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-brand md:text-5xl">{t.impact.title}</h1>
    <p class="mt-6 max-w-3xl text-lg text-gray-700">{t.impact.intro}</p>
  </section>

  {
    t.impact.programmes.map((p, idx) => (
      <section class={idx % 2 === 0 ? 'bg-gray-50 py-16' : 'py-16'}>
        <div class="container mx-auto px-4">
          <div
            class={`aspect-[16/9] w-full overflow-hidden rounded-lg bg-gradient-to-br ${p.slug === 'turkana' ? 'from-brand to-brand-accent' : 'from-brand-accent to-brand'}`}
          >
            <img
              src={`/photos/${p.slug}/hero.jpg`}
              alt={`${p.name} — ${p.location}`}
              class="h-full w-full object-cover"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>

          <div class="mt-10 grid gap-10 md:grid-cols-5">
            <div class="md:col-span-3">
              <p class="text-sm font-semibold uppercase tracking-wide text-brand-accent">
                {p.location} · {p.partner}
              </p>
              <h2 class="mt-2 text-3xl font-bold text-brand">{p.name}</h2>
              <p class="mt-4 text-lg text-gray-700">{p.summary}</p>
              <p class="mt-4 text-gray-700">{p.body}</p>
            </div>
            <div class="md:col-span-2">
              <div class="rounded-lg border border-gray-200 bg-white p-6">
                <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
                  Programme Highlights
                </h3>
                <ul class="mt-4 space-y-2">
                  {p.highlights.map((h) => (
                    <li class="flex items-start gap-2 text-sm text-gray-700">
                      <span class="mt-1 inline-block h-2 w-2 shrink-0 rounded-full bg-brand-accent" />
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          {galleries[p.slug] && (
            <div class="mt-10">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
                From the {p.location} programme
              </h3>
              <div class="mt-4 grid grid-cols-2 gap-3 md:grid-cols-3">
                {galleries[p.slug].map((img) => (
                  <a
                    href={`/photos/${p.slug}/${img}`}
                    class="block aspect-square overflow-hidden rounded-lg bg-gray-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
                  >
                    <img
                      src={`/photos/${p.slug}/${img}`}
                      alt={`${p.name} programme moment`}
                      class="h-full w-full object-cover transition duration-300 hover:scale-105"
                      loading="lazy"
                    />
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    ))
  }

  <section class="container mx-auto px-4 py-16">
    <div class="rounded-lg bg-brand p-10 text-white">
      <h2 class="text-2xl font-bold">{t.support.contactTitle}</h2>
      <p class="mt-3 max-w-2xl text-blue-100">{t.support.contactBody}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={`${base}/support`}
          class="rounded bg-brand-accent px-5 py-2.5 font-semibold text-white hover:bg-brand-accent-dark"
        >
          {t.nav.support}
        </a>
        <a
          href={`${base}/contact`}
          class="rounded border border-white px-5 py-2.5 font-semibold text-white hover:bg-white hover:text-brand"
        >
          {t.nav.contact}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
