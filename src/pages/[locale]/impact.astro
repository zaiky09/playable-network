---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, useTranslations, type Locale } from '@/i18n/config';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const base = `/${locale}`;

const galleries: Record<string, string[]> = {
  turkana: [
    'turkana-coach-equipment-distribution.jpg',
    'turkana-mentoring-session-03.jpg',
    'turkana-players-huddle-dirt-pitch.jpg',
    'turkana-pitch-training-01.jpg',
    'turkana-match-orange-vests-dirt-field.jpg',
    'turkana-coach-training-session.jpg',
  ],
  mombasa: [
    'mombasa-match-02.jpg',
    'mombasa-match-03.jpg',
    'mombasa-action.jpg',
    'mombasa-team-photo.jpg',
    'mombasa-team-photo-jeep.jpg',
    'mombasa-group.jpg',
  ],
};

// Pillar tokens — accessible variants for light-section pillar cards.
// Gold (Y, #fbbf24) fails AA on white at body size, so the Y card uses
// brand-accent-dark (#c2410c, ~5.9:1) for the letter glyph and headline.
// The gold token stays on the top-border (decorative ≥3:1 floor OK).
const pillarLetterColor: Record<string, string> = {
  P: 'text-brand',
  L: 'text-brand-cyan',
  A: 'text-brand-accent',
  Y: 'text-brand-accent-dark',
};
const pillarBorderColor: Record<string, string> = {
  P: 'border-brand',
  L: 'border-brand-cyan',
  A: 'border-brand-accent',
  Y: 'border-brand-gold',
};
// Letter-only pillar chips on white background (per-programme block).
const chipBorderClass: Record<string, string> = {
  P: 'border-brand',
  L: 'border-brand-cyan',
  A: 'border-brand-accent',
  Y: 'border-brand-gold',
};
---

<BaseLayout locale={locale} title={t.impact.title} description={t.impact.metaDescription}>
  <section class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-brand md:text-5xl">{t.impact.title}</h1>
    <p class="mt-6 max-w-3xl text-lg text-gray-700">{t.impact.intro}</p>
  </section>

  {/* ============================================================
      Impact by PLAY pillar — methodology lens at the top. NO
      programme anchor (review fix), NO bulleted outcomes (avoids
      duplicating per-programme highlights below).
      ============================================================ */}
  {t.impact.byPillar && (
    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-bold text-brand md:text-3xl">{t.impact.frameworkSectionTitle}</h2>
        <p class="mt-3 max-w-3xl text-gray-700">{t.impact.frameworkSectionIntro}</p>

        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {t.impact.byPillar.map((pillar) => (
            <article
              class={`rounded-2xl border-t-4 ${pillarBorderColor[pillar.letter]} bg-white p-6 shadow-sm ring-1 ring-gray-100`}
            >
              <span
                aria-hidden="true"
                class={`block text-6xl font-bold leading-none drop-shadow ${pillarLetterColor[pillar.letter]}`}
              >
                {pillar.letter}
              </span>
              <h3 class="mt-4 text-lg font-bold text-brand">{pillar.name}</h3>
              <p class={`mt-3 text-base font-semibold ${pillarLetterColor[pillar.letter]}`}>
                {pillar.headline}
              </p>
              <p class="mt-3 text-sm text-gray-700">{pillar.summary}</p>
            </article>
          ))}
        </div>

        <p class="mt-10 max-w-3xl text-sm italic text-gray-600">
          <a href={`${base}/framework`} class="font-semibold text-brand-accent hover:underline">
            See the full framework →
          </a>
        </p>
      </div>
    </section>
  )}

  {
    t.impact.programmes.map((p, idx) => (
      <section class={idx % 2 === 0 ? 'bg-white py-16' : 'bg-gray-50 py-16'}>
        <div class="container mx-auto px-4">
          <div
            class={`aspect-[16/9] w-full overflow-hidden rounded-lg bg-gradient-to-br ${p.slug === 'turkana' ? 'from-brand to-brand-accent' : 'from-brand-accent to-brand'}`}
          >
            <img
              src={`/photos/${p.slug}/hero.webp`}
              alt={`${p.name} — ${p.location}`}
              class="h-full w-full object-cover"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>

          <div class="mt-10 grid gap-10 md:grid-cols-5">
            <div class="md:col-span-3">
              <p class="text-sm font-semibold uppercase tracking-wide text-brand-accent">
                {p.location} · {p.partner}
              </p>
              <h2 class="mt-2 text-3xl font-bold text-brand">{p.name}</h2>
              {p.pillars && p.pillars.length > 0 && (
                <div class="mt-4 flex flex-wrap items-center gap-2" aria-label="PLAY Framework pillars addressed by this programme">
                  <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-500">Pillars:</span>
                  {p.pillars.map((letter) => (
                    <span
                      class={`inline-flex h-7 w-7 items-center justify-center rounded-full border-t-2 ${chipBorderClass[letter]} bg-white text-xs font-bold text-brand ring-1 ring-gray-200`}
                      title={letter}
                      lang="en"
                    >
                      {letter}
                    </span>
                  ))}
                </div>
              )}
              <p class="mt-4 text-lg text-gray-700">{p.summary}</p>
              <p class="mt-4 text-gray-700">{p.body}</p>
            </div>
            <div class="md:col-span-2">
              <div class="rounded-lg border border-gray-200 bg-white p-6">
                <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
                  Programme Highlights
                </h3>
                <ul class="mt-4 space-y-2">
                  {p.highlights.map((h) => (
                    <li class="flex items-start gap-2 text-sm text-gray-700">
                      <span class="mt-1 inline-block h-2 w-2 shrink-0 rounded-full bg-brand-accent" />
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          {galleries[p.slug] && (
            <div class="mt-10" data-lightbox-group={p.slug}>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
                From the {p.location} programme
              </h3>
              <div class="mt-4 grid grid-cols-2 gap-3 md:grid-cols-3">
                {galleries[p.slug].map((img, i) => (
                  <button
                    type="button"
                    class="group block aspect-square overflow-hidden rounded-lg bg-gray-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2"
                    data-lightbox-trigger
                    data-src={`/photos/${p.slug}/${img}`}
                    data-caption={`${p.location} · ${p.partner} · Photo ${i + 1} of ${galleries[p.slug].length}`}
                    aria-label={`Open photo ${i + 1} of ${galleries[p.slug].length}`}
                  >
                    <img
                      src={`/photos/${p.slug}/${img}`}
                      alt=""
                      class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    ))
  }

  <section class="container mx-auto px-4 py-16">
    <div class="rounded-lg bg-brand p-10 text-white">
      <h2 class="text-2xl font-bold">{t.support.contactTitle}</h2>
      <p class="mt-3 max-w-2xl text-blue-100">{t.support.contactBody}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={`${base}/support`}
          class="rounded bg-brand-accent px-5 py-2.5 font-semibold text-white hover:bg-brand-accent-dark"
        >
          {t.nav.support}
        </a>
        <a
          href={`${base}/contact`}
          class="rounded border border-white px-5 py-2.5 font-semibold text-white hover:bg-white hover:text-brand"
        >
          {t.nav.contact}
        </a>
      </div>
    </div>
  </section>

  <!-- Lightbox dialog (shared across all galleries on this page) -->
  <dialog id="lightbox" class="lightbox" aria-label="Photo viewer">
    <div class="relative flex h-full w-full items-center justify-center">
      <button
        type="button"
        data-lightbox-close
        aria-label="Close viewer"
        class="absolute right-4 top-4 z-10 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur transition hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <button
        type="button"
        data-lightbox-prev
        aria-label="Previous photo"
        class="absolute left-4 z-10 hidden h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur transition hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent disabled:opacity-30 md:inline-flex"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <button
        type="button"
        data-lightbox-next
        aria-label="Next photo"
        class="absolute right-4 z-10 hidden h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur transition hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent disabled:opacity-30 md:inline-flex"
        style="top: 50%; transform: translateY(-50%);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <img
        data-lightbox-image
        src=""
        alt=""
        class="max-h-[85vh] max-w-[92vw] object-contain"
      />

      <p
        data-lightbox-caption
        class="absolute bottom-6 left-1/2 max-w-[90vw] -translate-x-1/2 rounded bg-black/40 px-4 py-2 text-center text-sm text-white backdrop-blur"
      ></p>
    </div>
  </dialog>

  <script>
    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    if (dialog) {
      const dialogImg = dialog.querySelector('[data-lightbox-image]') as HTMLImageElement;
      const dialogCap = dialog.querySelector('[data-lightbox-caption]') as HTMLParagraphElement;
      const closeBtn = dialog.querySelector('[data-lightbox-close]') as HTMLButtonElement;
      const prevBtn = dialog.querySelector('[data-lightbox-prev]') as HTMLButtonElement;
      const nextBtn = dialog.querySelector('[data-lightbox-next]') as HTMLButtonElement;

      type Item = { src: string; caption: string };
      let items: Item[] = [];
      let index = 0;

      const update = () => {
        const item = items[index];
        if (!item) return;
        dialogImg.src = item.src;
        dialogImg.alt = item.caption;
        dialogCap.textContent = item.caption;
        prevBtn.disabled = index === 0;
        nextBtn.disabled = index === items.length - 1;
      };

      const open = (groupItems: Item[], startIndex: number) => {
        items = groupItems;
        index = startIndex;
        update();
        dialog.showModal();
      };

      const close = () => {
        dialog.close();
        dialogImg.src = '';
      };

      const goPrev = () => {
        if (index > 0) {
          index--;
          update();
        }
      };

      const goNext = () => {
        if (index < items.length - 1) {
          index++;
          update();
        }
      };

      // Wire up triggers — each gallery group is independent
      document.querySelectorAll('[data-lightbox-group]').forEach((group) => {
        const triggers = group.querySelectorAll<HTMLElement>('[data-lightbox-trigger]');
        const groupItems: Item[] = Array.from(triggers).map((t) => ({
          src: t.dataset.src || '',
          caption: t.dataset.caption || '',
        }));
        triggers.forEach((trigger, i) => {
          trigger.addEventListener('click', () => open(groupItems, i));
        });
      });

      closeBtn.addEventListener('click', close);
      prevBtn.addEventListener('click', goPrev);
      nextBtn.addEventListener('click', goNext);

      // Close on backdrop click (anywhere outside the image/buttons)
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) close();
      });

      // Keyboard navigation
      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goPrev();
        if (e.key === 'ArrowRight') goNext();
      });
    }
  </script>
</BaseLayout>
