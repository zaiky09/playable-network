---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, useTranslations, type Locale } from '@/i18n/config';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const base = `/${locale}`;

// Pillar accent class for letter-only chip on glass-morphism dark card.
// Letter text stays white (best contrast on white/15 backdrop); pillar identity
// is carried by a 2px top-border on the chip (review fix for color-on-glass
// contrast failure with gold/cyan).
const chipBorderClass: Record<string, string> = {
  P: 'border-brand-light',
  L: 'border-brand-cyan',
  A: 'border-brand-accent',
  Y: 'border-brand-gold',
};
---

<BaseLayout locale={locale} title={t.programs.title} description={t.programs.metaDescription}>
  <section class="bg-gradient-to-br from-brand-light/5 to-brand-accent/5 py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="grid gap-12 md:grid-cols-2 md:items-center">
        <div>
          <h1 class="text-4xl font-bold leading-tight text-brand md:text-5xl">{t.programs.title}</h1>
          <p class="mt-6 max-w-2xl text-lg text-gray-700">{t.programs.intro}</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href={`${base}/impact`}
              class="inline-flex rounded bg-brand-accent px-6 py-3 text-sm font-semibold text-white shadow-md hover:bg-brand-accent-dark transition"
            >
              See our Impact →
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 rounded-3xl bg-brand-accent/10 blur-2xl" aria-hidden="true"></div>
          <img
            src="/photos/OurProgramme.webp"
            alt="PlayAble Network programmes in action"
            width="500"
            height="500"
            class="relative rounded-3xl shadow-2xl object-cover w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand">Pillars of Work</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {
          t.pillars.map((pillar) => (
            <div class="rounded-lg border-t-4 border-brand-accent bg-white p-6 shadow-sm">
              <h3 class="text-lg font-semibold text-brand">{pillar.title}</h3>
              <p class="mt-2 text-sm text-gray-700">{pillar.blurb}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Framework callout strip — establishes the methodology lens before Programme Areas. */}
  {t.programs.frameworkCallout && (
    <section class="bg-brand py-6 text-white">
      <div class="container mx-auto flex flex-wrap items-center justify-between gap-4 px-4">
        <p class="flex items-center gap-3 text-sm font-semibold">
          <span class="flex items-center gap-1" aria-hidden="true">
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border-t-2 border-brand-light bg-white/10 text-xs font-bold backdrop-blur">P</span>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border-t-2 border-brand-cyan bg-white/10 text-xs font-bold backdrop-blur">L</span>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border-t-2 border-brand-accent bg-white/10 text-xs font-bold backdrop-blur">A</span>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border-t-2 border-brand-gold bg-white/10 text-xs font-bold backdrop-blur">Y</span>
          </span>
          <span>{t.programs.frameworkCallout.text}</span>
        </p>
        <a href={`${base}/framework`} class="text-sm font-semibold text-brand-gold hover:underline">
          {t.programs.frameworkCallout.linkLabel} →
        </a>
      </div>
    </section>
  )}

  <section class="relative isolate overflow-hidden bg-brand-dark text-white">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/video/impact-poster.jpg"
      aria-hidden="true"
      class="absolute inset-0 -z-10 h-full w-full object-cover motion-reduce:hidden"
      disablepictureinpicture
    >
      <source src="/video/OurProgram-mobile.mp4" type="video/mp4" media="(max-width: 768px)" />
      <source src="/video/OurProgram.mp4" type="video/mp4" />
    </video>

    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 bg-gradient-to-br from-brand-dark/90 via-brand-dark/80 to-brand-accent/35"
    ></div>

    <div class="relative z-10 container mx-auto px-4 py-16">
      <h2 class="text-3xl font-bold text-white md:text-4xl">{t.programs.areasTitle}</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          t.programs.areas.map((area) => (
            <article class="rounded-3xl border border-white/20 bg-white/10 p-6 shadow-lg backdrop-blur-sm">
              <h3 class="text-lg font-semibold text-brand-accent">{area.title}</h3>
              <p class="mt-3 text-sm text-blue-100">{area.body}</p>
              {area.pillars && area.pillars.length > 0 && (
                <div class="mt-4 flex flex-wrap items-center gap-2" aria-label="PLAY Framework pillars addressed">
                  {area.pillars.map((letter) => (
                    <span
                      class={`inline-flex h-7 w-7 items-center justify-center rounded-full border-t-2 ${chipBorderClass[letter]} bg-white/15 text-xs font-bold text-white backdrop-blur-sm`}
                      title={letter}
                      lang="en"
                    >
                      {letter}
                    </span>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand">{t.programs.modelTitle}</h2>
      <p class="mt-2 max-w-2xl text-gray-700">{t.programs.modelIntro}</p>
      <ol class="mt-10 grid gap-4 md:grid-cols-5">
        {
          t.programs.modelSteps.map((step, i) => (
            <li class="relative rounded-lg bg-white p-5 shadow-sm">
              <span class="absolute -top-3 -left-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-accent text-sm font-bold text-white">
                {i + 1}
              </span>
              <h3 class="mt-2 text-base font-bold text-brand">{step.title}</h3>
              <p class="mt-2 text-xs text-gray-700">{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="container mx-auto px-4 py-16">
    <div class="rounded-lg border-2 border-brand-accent bg-white p-10">
      <h2 class="text-2xl font-bold text-brand">{t.programs.visionTitle}</h2>
      <p class="mt-4 max-w-3xl text-lg text-gray-700">{t.programs.visionBody}</p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a
          href={`${base}/impact`}
          class="rounded bg-brand-accent px-5 py-2.5 font-semibold text-white hover:bg-brand-accent-dark"
        >
          {t.impact.title} →
        </a>
        <a
          href={`${base}/partners`}
          class="rounded border border-brand px-5 py-2.5 font-semibold text-brand hover:bg-brand hover:text-white"
        >
          {t.partners.title}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
