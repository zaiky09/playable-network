---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, useTranslations, type Locale } from '@/i18n/config';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const base = `/${locale}`;
---

<BaseLayout locale={locale} title={t.programs.title}>
  <section class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-brand md:text-5xl">{t.programs.title}</h1>
    <p class="mt-6 max-w-3xl text-lg text-gray-700">{t.programs.intro}</p>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand">Pillars of Work</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {
          t.pillars.map((pillar) => (
            <div class="rounded-lg border-t-4 border-brand-accent bg-white p-6 shadow-sm">
              <h3 class="text-lg font-semibold text-brand">{pillar.title}</h3>
              <p class="mt-2 text-sm text-gray-700">{pillar.blurb}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-brand">{t.programs.areasTitle}</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        t.programs.areas.map((area) => (
          <article class="rounded-lg border border-gray-200 bg-white p-6">
            <h3 class="text-lg font-semibold text-brand-accent">{area.title}</h3>
            <p class="mt-3 text-sm text-gray-700">{area.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-brand">{t.programs.modelTitle}</h2>
      <p class="mt-2 max-w-2xl text-gray-700">{t.programs.modelIntro}</p>
      <ol class="mt-10 grid gap-4 md:grid-cols-5">
        {
          t.programs.modelSteps.map((step, i) => (
            <li class="relative rounded-lg bg-white p-5 shadow-sm">
              <span class="absolute -top-3 -left-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-accent text-sm font-bold text-white">
                {i + 1}
              </span>
              <h3 class="mt-2 text-base font-bold text-brand">{step.title}</h3>
              <p class="mt-2 text-xs text-gray-700">{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="container mx-auto px-4 py-16">
    <div class="rounded-lg border-2 border-brand-accent bg-white p-10">
      <h2 class="text-2xl font-bold text-brand">{t.programs.visionTitle}</h2>
      <p class="mt-4 max-w-3xl text-lg text-gray-700">{t.programs.visionBody}</p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a
          href={`${base}/impact`}
          class="rounded bg-brand-accent px-5 py-2.5 font-semibold text-white hover:bg-brand-accent-dark"
        >
          {t.impact.title} →
        </a>
        <a
          href={`${base}/partners`}
          class="rounded border border-brand px-5 py-2.5 font-semibold text-brand hover:bg-brand hover:text-white"
        >
          {t.partners.title}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
